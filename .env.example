# Samantha — environment secrets template
# Copy to .env and fill in real values. Never commit .env

# OpenClaw
OPENCLAW_TOKEN=your_openclaw_bearer_token_here

# Vapi
VAPI_KEY=your_vapi_private_key_here
VAPI_INCOMING_AGENT_ID=your_incoming_agent_id_here
VAPI_OUTGOING_AGENT_ID=your_outgoing_agent_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
ALAIN_NUMBER=+1xxxxxxxxxx

# Blink
BLINK_EMAIL=your_blink_email_here
BLINK_PASSWORD=your_blink_password_here

# ngrok
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
